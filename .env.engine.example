# Конфигурация автономного движка на отдельной машине.
# Скопируй в .env.engine и заполни значения:  cp .env.engine.example .env.engine

# === Обязательно ===

# Уникальный id движка (буквы/цифры). Не должен совпадать с уже существующими (b1..b6 и т.д.).
SEEDING_ENGINE_ID=b7

# Адрес оркестратора (control plane / API), доступный С ЭТОЙ машины.
SEEDING_ORCHESTRATOR_URL=http://ORCHESTRATOR_HOST:8000

# Общий ключ саморегистрации. Должен совпадать с SEEDING_ENGINE_REGISTER_KEY оркестратора.
SEEDING_ENGINE_REGISTER_KEY=ct400-engine-register

# Токен внутреннего API движка. Должен совпадать с SEEDING_ENGINE_API_TOKEN оркестратора.
# Оркестратор шлёт его в заголовке X-Engine-Token; без него движок вернёт 401.
SEEDING_ENGINE_API_TOKEN=ct400-engine-api-token

# Адрес ЭТОГО движка, по которому его достучится ОРКЕСТРАТОР (внешний IP этой машины + порт API).
# Порт здесь = SEEDING_ENGINE_API_PORT ниже.
SEEDING_ENGINE_ADVERTISE_URL=http://THIS_HOST_IP:8081

# BitTorrent listen-порт (TCP+UDP). Открой его на файрволе/роутере для входящих пиров.
SEEDING_ENGINE_LISTEN_PORT=50007

# === Необязательно ===

# Порт внутреннего API движка на хосте (по умолчанию 8081).
# БЕЗОПАСНОСТЬ: ограничь доступ к нему IP оркестратора — у API пока нет аутентификации.
SEEDING_ENGINE_API_PORT=8081

# Период heartbeat в секундах (по умолчанию 60). Оркестратор выбывает движок после
# SEEDING_ENGINE_TTL без сигнала (по умолчанию 180с).
SEEDING_ENGINE_HEARTBEAT_INTERVAL=60

# === Шифрование (TLS) ===
# 1 = включить TLS на внутреннем API. Тогда:
#   - положи certs/ca.crt, certs/engine.crt, certs/engine.key рядом (сгенерируй на машине
#     с CA: scripts/gen-certs.sh "DNS:<host>,IP:<host-ip>", скопируй три файла сюда);
#   - SEEDING_ENGINE_ADVERTISE_URL должен быть https://...
#   - на оркестраторе укажи SEEDING_ENGINE_TLS_CA=/certs/ca.crt
SEEDING_ENGINE_TLS=0
