{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["seeding"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "title": "Torrent Seeding",
  "uid": "seeding-main",
  "panels": [
    {
      "type": "stat",
      "title": "Движки онлайн",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "sum(seeding_engine_up)", "legendFormat": "online", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Раздачи (всего)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "seeding_torrents_total_count", "legendFormat": "torrents", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Скачивание (сумма)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        { "expr": "sum(seeding_engine_download_rate_bytes)", "legendFormat": "down", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Отдача (сумма)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        { "expr": "sum(seeding_engine_upload_rate_bytes)", "legendFormat": "up", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Скорость по движкам (отдача)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        { "expr": "seeding_engine_upload_rate_bytes", "legendFormat": "{{engine}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Скорость по движкам (скачивание)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "targets": [
        { "expr": "seeding_engine_download_rate_bytes", "legendFormat": "{{engine}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Раздачи по статусу",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "seeding_torrents", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Свободно на диске (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "targets": [
        { "expr": "seeding_engine_disk_free_bytes / seeding_engine_disk_total_bytes * 100", "legendFormat": "{{engine}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Пиры / сиды (сумма)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "sum(seeding_engine_peers)", "legendFormat": "peers", "refId": "A" },
        { "expr": "sum(seeding_engine_seeds)", "legendFormat": "seeds", "refId": "B" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Очередь ARQ (задачи)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "seeding_queue_jobs", "legendFormat": "{{state}}", "refId": "A" }
      ]
    }
  ]
}
